# ---- OpenRouter (https://openrouter.ai/keys) ----
# Get a free API key and paste it here
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of free models (first is primary, rest are fallbacks).
# All IDs must be free-tier models. Defaults are set in app/config.py; override only if you want.
OPENROUTER_MODELS=openai/gpt-oss-120b:free,nvidia/nemotron-3-super-120b-a12b:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free,openrouter/free

# ---- HTTP headers OpenRouter requires for analytics/ranking ----
OPENROUTER_APP_URL=https://openwork.local
OPENROUTER_APP_NAME=OpenWork AI Service

# ---- Server ----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
